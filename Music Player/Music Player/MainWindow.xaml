<Window x:Class="Music_Player.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Music_Player"
        mc:Ignorable="d"
        Title="Music Player"
        Height="900"
        Width="1500"
        MinHeight="700"
        MinWidth="1100"
        WindowStartupLocation="CenterScreen"
        Background="#121212">
    <Window.Resources>
        <SolidColorBrush x:Key="BaseBg" Color="#121212" />
        <SolidColorBrush x:Key="PanelBg" Color="#181818" />
        <SolidColorBrush x:Key="AltPanelBg" Color="#1E1E1E" />
        <SolidColorBrush x:Key="PlayerBg" Color="#101010" />
        <SolidColorBrush x:Key="AccentGreen" Color="#1DB954" />
        <SolidColorBrush x:Key="PrimaryText" Color="#FFFFFF" />
        <SolidColorBrush x:Key="SecondaryText" Color="#B3B3B3" />
        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource SecondaryText}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter Margin="{TemplateBinding Padding}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource PrimaryText}" />
                    <Setter Property="Background" Value="#252525" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="CardButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource PrimaryText}" />
            <Setter Property="Background" Value="#2A2A2A" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#343434" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="RecentPanelButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource PrimaryText}" />
            <Setter Property="Background" Value="#252525" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#333333" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="PlaylistEntryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryText}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter Margin="{TemplateBinding Padding}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#252525" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource BaseBg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="68" />
            <RowDefinition Height="*" />
            <RowDefinition Height="96" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="320" />
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.ColumnSpan="3" Background="#141414" BorderBrush="#232323" BorderThickness="0,0,0,1">
            <Grid Margin="16,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="22" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button Content="Back" Width="52" Height="32" Margin="0,0,8,0" Background="#252525" Foreground="{StaticResource PrimaryText}" BorderBrush="Transparent" />
                <Button Grid.Column="1" Content="Next" Width="52" Height="32" Background="#252525" Foreground="{StaticResource PrimaryText}" BorderBrush="Transparent" />

                <Border Grid.Column="3" Height="40" CornerRadius="20" Background="#2A2A2A" VerticalAlignment="Center">
                    <DockPanel Margin="14,0">
                        <TextBlock Text="Search" VerticalAlignment="Center" Foreground="{StaticResource SecondaryText}" FontSize="13" Margin="0,0,8,0" />
                        <TextBox Text="Search songs, artists, albums..." Background="Transparent" BorderThickness="0" Foreground="{StaticResource SecondaryText}" FontSize="13" VerticalContentAlignment="Center" />
                    </DockPanel>
                </Border>

            </Grid>
        </Border>

        <Border Grid.Row="1" Grid.Column="0" Background="{StaticResource PanelBg}" Margin="8,8,6,8" CornerRadius="10">
            <Grid Margin="14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="20" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Text="Music Player" Foreground="{StaticResource PrimaryText}" FontSize="20" FontWeight="Bold" />
                <Button x:Name="HomeSidebarButton" Grid.Row="1" Content="Home" Style="{StaticResource SidebarButtonStyle}" Margin="0,12,0,0" Click="HomeButton_Click" />
                <Button Grid.Row="2" Content="Browse" Style="{StaticResource SidebarButtonStyle}" Margin="0,4,0,0" />
                <Button Grid.Row="3" Content="Upload music" Style="{StaticResource SidebarButtonStyle}" Margin="0,4,0,0" Click="UploadMusic_Click" />

                <TextBlock Grid.Row="5" Text="Your Library" Foreground="{StaticResource SecondaryText}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" />
                <ScrollViewer Grid.Row="6" VerticalScrollBarVisibility="Auto" Margin="0,10,0,0">
                    <StackPanel>
                        <Button x:Name="OpenCreatePlaylistButton" Content="+ New Playlist" Style="{StaticResource SidebarButtonStyle}" Margin="0,0,0,8" Click="OpenCreatePlaylistModal_Click" />
                        <Button x:Name="AllSongsSidebarButton" Content="All songs" Style="{StaticResource SidebarButtonStyle}" Click="OpenAllSongsPlaylist_Click" />
                        <ItemsControl x:Name="SidebarPlaylistsItems" Margin="0,6,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Style="{StaticResource PlaylistEntryButtonStyle}" Click="SidebarPlaylistButton_Click" Tag="{Binding}">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}" Foreground="{StaticResource PrimaryText}" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding Genre}" Foreground="{StaticResource SecondaryText}" FontSize="11">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Genre}" Value="">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </Button>
                                        <Button Grid.Column="1" Content="Edit" Width="40" Height="26" Margin="4,0,0,0" Background="#2A2A2A" Foreground="{StaticResource SecondaryText}" BorderBrush="Transparent" Click="OpenEditPlaylistModal_Click" Tag="{Binding}" />
                                        <Button Grid.Column="2" Content="Del" Width="36" Height="26" Margin="4,0,0,0" Background="#3A1F1F" Foreground="{StaticResource SecondaryText}" BorderBrush="Transparent" Click="DeletePlaylist_Click" Tag="{Binding}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <Border Grid.Row="1" Grid.Column="1" Background="{StaticResource AltPanelBg}" Margin="0,8,0,8" CornerRadius="10">
            <Grid>
                <ScrollViewer x:Name="HomePanelView" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">
                        <TextBlock Text="Good evening" FontSize="30" FontWeight="Bold" Foreground="{StaticResource PrimaryText}" />
                        <Grid Margin="0,18,0,30">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="44" />
                            </Grid.ColumnDefinitions>

                            <Button x:Name="HomeCarouselLeftButton" Grid.Column="0" Content="&lt;" Width="32" Height="32" VerticalAlignment="Center" HorizontalAlignment="Center" Background="#2A2A2A" Foreground="{StaticResource PrimaryText}" BorderBrush="Transparent" Click="HomeCarouselLeftButton_Click" />

                            <Button x:Name="HomePlaylistCard1" Grid.Column="1" Height="86" Style="{StaticResource CardButtonStyle}" Click="HomePlaylistCard_Click">
                                <DockPanel>
                                    <Border x:Name="HomePlaylistArt1" Width="74" Background="#3D3D3D" />
                                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                                        <TextBlock x:Name="HomePlaylistTitle1" Foreground="{StaticResource PrimaryText}" FontWeight="SemiBold" />
                                        <TextBlock x:Name="HomePlaylistGenre1" Foreground="{StaticResource SecondaryText}" FontSize="11" />
                                    </StackPanel>
                                </DockPanel>
                            </Button>

                            <Button x:Name="HomePlaylistCard2" Grid.Column="3" Height="86" Style="{StaticResource CardButtonStyle}" Click="HomePlaylistCard_Click">
                                <DockPanel>
                                    <Border x:Name="HomePlaylistArt2" Width="74" Background="#3A5647" />
                                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                                        <TextBlock x:Name="HomePlaylistTitle2" Foreground="{StaticResource PrimaryText}" FontWeight="SemiBold" />
                                        <TextBlock x:Name="HomePlaylistGenre2" Foreground="{StaticResource SecondaryText}" FontSize="11" />
                                    </StackPanel>
                                </DockPanel>
                            </Button>

                            <Button x:Name="HomePlaylistCard3" Grid.Column="5" Height="86" Style="{StaticResource CardButtonStyle}" Click="HomePlaylistCard_Click">
                                <DockPanel>
                                    <Border x:Name="HomePlaylistArt3" Width="74" Background="#5B3A3A" />
                                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                                        <TextBlock x:Name="HomePlaylistTitle3" Foreground="{StaticResource PrimaryText}" FontWeight="SemiBold" />
                                        <TextBlock x:Name="HomePlaylistGenre3" Foreground="{StaticResource SecondaryText}" FontSize="11" />
                                    </StackPanel>
                                </DockPanel>
                            </Button>

                            <Button x:Name="HomeCarouselRightButton" Grid.Column="6" Content="&gt;" Width="32" Height="32" VerticalAlignment="Center" HorizontalAlignment="Center" Background="#2A2A2A" Foreground="{StaticResource PrimaryText}" BorderBrush="Transparent" Click="HomeCarouselRightButton_Click" />
                        </Grid>

                        <DockPanel Margin="0,0,0,12">
                            <TextBlock Text="Recently played" FontSize="22" FontWeight="Bold" Foreground="{StaticResource PrimaryText}" />
                            <TextBlock Text="Show all" Foreground="{StaticResource SecondaryText}" VerticalAlignment="Bottom" HorizontalAlignment="Right" DockPanel.Dock="Right" />
                        </DockPanel>

                        <UniformGrid Columns="4" Rows="1">
                            <Button Margin="0,0,12,0" Style="{StaticResource RecentPanelButtonStyle}">
                                <StackPanel Margin="12">
                                    <Border Height="140" Background="#4A4A4A" CornerRadius="8" />
                                    <TextBlock Text="Ambient Focus" Foreground="{StaticResource PrimaryText}" FontWeight="SemiBold" Margin="0,10,0,4" />
                                    <TextBlock Text="Calm, instrumental and minimal." Foreground="{StaticResource SecondaryText}" FontSize="12" TextWrapping="Wrap" />
                                </StackPanel>
                            </Button>
                            <Button Margin="0,0,12,0" Style="{StaticResource RecentPanelButtonStyle}">
                                <StackPanel Margin="12">
                                    <Border Height="140" Background="#44556B" CornerRadius="8" />
                                    <TextBlock Text="Indie Morning" Foreground="{StaticResource PrimaryText}" FontWeight="SemiBold" Margin="0,10,0,4" />
                                    <TextBlock Text="Fresh indie picks for smooth starts." Foreground="{StaticResource SecondaryText}" FontSize="12" TextWrapping="Wrap" />
                                </StackPanel>
                            </Button>
                            <Button Margin="0,0,12,0" Style="{StaticResource RecentPanelButtonStyle}">
                                <StackPanel Margin="12">
                                    <Border Height="140" Background="#5D3D5D" CornerRadius="8" />
                                    <TextBlock Text="Neon Nights" Foreground="{StaticResource PrimaryText}" FontWeight="SemiBold" Margin="0,10,0,4" />
                                    <TextBlock Text="Synthwave and retro pop energy." Foreground="{StaticResource SecondaryText}" FontSize="12" TextWrapping="Wrap" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource RecentPanelButtonStyle}">
                                <StackPanel Margin="12">
                                    <Border Height="140" Background="#556048" CornerRadius="8" />
                                    <TextBlock Text="Acoustic Sessions" Foreground="{StaticResource PrimaryText}" FontWeight="SemiBold" Margin="0,10,0,4" />
                                    <TextBlock Text="Warm vocals and guitar essentials." Foreground="{StaticResource SecondaryText}" FontSize="12" TextWrapping="Wrap" />
                                </StackPanel>
                            </Button>
                        </UniformGrid>
                    </StackPanel>
                </ScrollViewer>

                <Border x:Name="PlaylistOverlayView" Background="{StaticResource AltPanelBg}" CornerRadius="10" Visibility="Collapsed">
                    <Grid Margin="20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0">
                            <TextBlock x:Name="PlaylistTitleText" Text="Playlist" FontSize="28" FontWeight="Bold" Foreground="{StaticResource PrimaryText}" />
                            <TextBlock Text="Click a song to play it" Margin="0,4,0,0" Foreground="{StaticResource SecondaryText}" />
                        </StackPanel>

                        <ListBox x:Name="PlaylistSongList" Grid.Row="1" Margin="0,20,0,0" Background="Transparent" BorderThickness="0" ScrollViewer.VerticalScrollBarVisibility="Auto" HorizontalContentAlignment="Stretch">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="BorderThickness" Value="0" />
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Button Background="#252525" BorderBrush="Transparent" Margin="0,0,0,8" Padding="12,10" Click="SongButton_Click" Tag="{Binding}" HorizontalContentAlignment="Stretch">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="56" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Title}" Foreground="{StaticResource PrimaryText}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding Artist}" Foreground="{StaticResource SecondaryText}" FontSize="12" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="{Binding Duration}" Foreground="{StaticResource SecondaryText}" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1" Grid.Column="2" Background="{StaticResource PanelBg}" Margin="6,8,8,8" CornerRadius="10">
            <StackPanel Margin="16">
                <TextBlock Text="Now Playing" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource PrimaryText}" />
                <Border Height="250" Margin="0,16,0,14" Background="#3B3B3B" CornerRadius="12" />
                <TextBlock x:Name="NowPlayingTitleText" Text="Midnight City" Foreground="{StaticResource PrimaryText}" FontWeight="Bold" FontSize="18" />
                <TextBlock x:Name="NowPlayingArtistText" Text="M83" Foreground="{StaticResource SecondaryText}" Margin="0,3,0,0" />

                <TextBlock Text="Up Next" Foreground="{StaticResource PrimaryText}" FontWeight="SemiBold" Margin="0,26,0,10" />
                <Border Background="#242424" CornerRadius="8" Padding="10" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="A Moment Apart" Foreground="{StaticResource PrimaryText}" />
                        <TextBlock Text="ODESZA" Foreground="{StaticResource SecondaryText}" FontSize="12" />
                    </StackPanel>
                </Border>
                <Border Background="#242424" CornerRadius="8" Padding="10" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="Sunset Lover" Foreground="{StaticResource PrimaryText}" />
                        <TextBlock Text="Petit Biscuit" Foreground="{StaticResource SecondaryText}" FontSize="12" />
                    </StackPanel>
                </Border>
                <Border Background="#242424" CornerRadius="8" Padding="10">
                    <StackPanel>
                        <TextBlock Text="Innerbloom" Foreground="{StaticResource PrimaryText}" />
                        <TextBlock Text="RUFUS DU SOL" Foreground="{StaticResource SecondaryText}" FontSize="12" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Grid.ColumnSpan="3" Background="{StaticResource PlayerBg}" BorderBrush="#252525" BorderThickness="0,1,0,0">
            <Grid Margin="16,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="300" />
                </Grid.ColumnDefinitions>

                <DockPanel Grid.Column="0" VerticalAlignment="Center">
                    <Border Width="58" Height="58" Background="#3D3D3D" CornerRadius="6" />
                    <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock x:Name="BottomNowPlayingTitleText" Text="Midnight City" Foreground="{StaticResource PrimaryText}" FontWeight="SemiBold" />
                        <TextBlock x:Name="BottomNowPlayingArtistText" Text="M83" Foreground="{StaticResource SecondaryText}" FontSize="12" />
                    </StackPanel>
                </DockPanel>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="Shf" Margin="6,0" Background="Transparent" BorderBrush="Transparent" Foreground="{StaticResource SecondaryText}" />
                        <Button x:Name="PrevControlButton" Content="Prev" Margin="6,0" Background="Transparent" BorderBrush="Transparent" Foreground="{StaticResource PrimaryText}" Click="PrevControlButton_Click" />
                        <Button x:Name="PlayPauseControlButton" Content="Play" Width="44" Height="36" Margin="6,0" Background="{StaticResource PrimaryText}" BorderBrush="Transparent" Foreground="#000000" FontWeight="Bold" Click="PlayPauseControlButton_Click" />
                        <Button x:Name="NextControlButton" Content="Next" Margin="6,0" Background="Transparent" BorderBrush="Transparent" Foreground="{StaticResource PrimaryText}" Click="NextControlButton_Click" />
                        <Button Content="Rpt" Margin="6,0" Background="Transparent" BorderBrush="Transparent" Foreground="{StaticResource SecondaryText}" />
                    </StackPanel>
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="36" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="36" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="1:18" Foreground="{StaticResource SecondaryText}" FontSize="11" VerticalAlignment="Center" />
                        <Grid Grid.Column="1" Height="4" VerticalAlignment="Center" Margin="10,0">
                            <Border Background="#5A5A5A" CornerRadius="2" />
                            <Border Background="{StaticResource PrimaryText}" Width="140" HorizontalAlignment="Left" CornerRadius="2" />
                        </Grid>
                        <TextBlock Grid.Column="2" Text="3:56" Foreground="{StaticResource SecondaryText}" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Right" />
                    </Grid>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="Vol" Foreground="{StaticResource SecondaryText}" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <Border Width="120" Height="4" CornerRadius="2" Background="#5A5A5A" VerticalAlignment="Center">
                        <Border Width="72" HorizontalAlignment="Left" Background="{StaticResource SecondaryText}" CornerRadius="2" />
                    </Border>
                </StackPanel>
            </Grid>
        </Border>
        <Border x:Name="CreatePlaylistModalOverlay" Grid.RowSpan="3" Grid.ColumnSpan="3" Background="#88000000" Visibility="Collapsed">
            <Border Width="640" Height="560" Background="{StaticResource PanelBg}" CornerRadius="12" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="CreatePlaylistModalTitle" Text="Create Playlist" FontSize="24" FontWeight="Bold" Foreground="{StaticResource PrimaryText}" />

                    <StackPanel Grid.Row="1" Margin="0,14,0,0">
                        <TextBlock Text="Playlist Name" Foreground="{StaticResource SecondaryText}" FontSize="12" />
                        <TextBox x:Name="NewPlaylistNameInput" Height="34" Margin="0,4,0,0" Background="#242424" Foreground="{StaticResource PrimaryText}" BorderBrush="#333333" />
                    </StackPanel>

                    <StackPanel Grid.Row="2" Margin="0,12,0,0">
                        <TextBlock Text="Playlist Genre (optional)" Foreground="{StaticResource SecondaryText}" FontSize="12" />
                        <TextBox x:Name="NewPlaylistGenreInput" Height="34" Margin="0,4,0,0" Background="#242424" Foreground="{StaticResource PrimaryText}" BorderBrush="#333333" />
                    </StackPanel>

                    <Grid Grid.Row="3" Margin="0,14,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="Select Songs" Foreground="{StaticResource SecondaryText}" FontSize="12" Margin="0,0,0,6" />
                        <ListBox x:Name="NewPlaylistSongsList"
                                 Grid.Row="1"
                                 Background="#1E1E1E"
                                 BorderBrush="#333333"
                                 SelectionMode="Multiple"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="10,8" />
                                    <Setter Property="Background" Value="#252525" />
                                    <Setter Property="Margin" Value="0,0,0,6" />
                                    <Setter Property="Foreground" Value="{StaticResource PrimaryText}" />
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#1DB954" />
                                            <Setter Property="Foreground" Value="#000000" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding Artist}" FontSize="11" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>

                    <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                        <Button Content="Cancel" Width="90" Height="34" Margin="0,0,8,0" Background="#2A2A2A" Foreground="{StaticResource PrimaryText}" BorderBrush="Transparent" Click="CloseCreatePlaylistModal_Click" />
                        <Button x:Name="CreatePlaylistConfirmButton" Content="Create Playlist" Width="130" Height="34" Background="{StaticResource AccentGreen}" Foreground="#000000" BorderBrush="Transparent" FontWeight="Bold" Click="CreatePlaylist_Click" />
                    </StackPanel>
                </Grid>
            </Border>
        </Border>
    </Grid>
</Window>
